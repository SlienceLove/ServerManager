     // 新增：一个用于清理路径的辅助方法，防止目录遍历攻击
    private string SanitizeSubpath(string subpath)
    {
        if (string.IsNullOrWhiteSpace(subpath))
        {
            return "";
        }

        subpath = subpath.Replace('/', Path.DirectorySeparatorChar).Replace('\\', Path.DirectorySeparatorChar);
        string[] segments = subpath.Split(Path.DirectorySeparatorChar, StringSplitOptions.RemoveEmptyEntries);
        var sanitizedSegments = new System.Collections.Generic.List<string>();
        foreach (var segment in segments)
        {
            if (segment == "..")
            {
                continue;
            }
            string cleanSegment = string.Join("_", segment.Split(Path.GetInvalidFileNameChars()));
            sanitizedSegments.Add(cleanSegment);
        }

        return string.Join(Path.DirectorySeparatorChar.ToString(), sanitizedSegments);
    }

    // 新增：服务器端读取下一行文本的辅助方法
    private async Task<string> ReadNextLineFromStream(NetworkStream networkStream, MemoryStream dataBuffer, byte[] readBuffer)
    {
        while (true)
        {
            byte[] buffer = dataBuffer.GetBuffer();
            int currentLength = (int)dataBuffer.Length;

            int newlineIndex = -1;
            for (int i = 0; i < currentLength; i++)
            {
                if (buffer[i] == (byte)'\n')
                {
                    newlineIndex = i;
                    break;
                }
            }

            if (newlineIndex >= 0)
            {
                string line = Encoding.UTF8.GetString(buffer, 0, newlineIndex).Trim();
                
                int bytesToShift = currentLength - (newlineIndex + 1);
                if (bytesToShift > 0)
                {
                    Buffer.BlockCopy(buffer, newlineIndex + 1, buffer, 0, bytesToShift);
                }
                dataBuffer.SetLength(bytesToShift);
                dataBuffer.Position = 0;

                return line;
            }

            if (dataBuffer.Capacity - dataBuffer.Length < readBuffer.Length)
            {
                dataBuffer.Capacity = (int)(dataBuffer.Length + readBuffer.Length * 2); 
            }

            int bytesRead = await networkStream.ReadAsync(readBuffer, 0, readBuffer.Length);
            if (bytesRead == 0)
            {
                if (dataBuffer.Length > 0)
                {
                    string remaining = Encoding.UTF8.GetString(buffer, 0, currentLength).Trim();
                    dataBuffer.SetLength(0);
                    dataBuffer.Position = 0;
                    return remaining;
                }
                throw new EndOfStreamException("Server: Network stream ended unexpectedly.");
            }
            dataBuffer.Position = dataBuffer.Length; 
            dataBuffer.Write(readBuffer, 0, bytesRead);
        }
    }

    // 新增：服务器端读取精确字节数的辅助方法 (用于 JSON 负载)
    private async Task<byte[]> ReadExactBytesFromStream(NetworkStream networkStream, MemoryStream dataBuffer, byte[] readBuffer, long bytesToRead)
    {
        MemoryStream resultBuffer = new MemoryStream();
        long totalBytesRead = 0;

        // 首先，从 dataBuffer 中消费数据
        if (dataBuffer.Length > 0)
        {
            long bytesFromDataBuffer = Math.Min(dataBuffer.Length, bytesToRead - totalBytesRead);
            if (bytesFromDataBuffer > 0)
            {
                byte[] temp = new byte[(int)bytesFromDataBuffer];
                dataBuffer.Position = 0;
                dataBuffer.Read(temp, 0, (int)bytesFromDataBuffer);
                await resultBuffer.WriteAsync(temp, 0, temp.Length);
                totalBytesRead += bytesFromDataBuffer;

                // 移动 dataBuffer 中剩余的数据到开头
                byte[] remainingData = dataBuffer.ToArray(); // 获取从当前 Position 到 Length 的所有数据
                dataBuffer.SetLength(0);
                dataBuffer.Position = 0;
                dataBuffer.Write(remainingData, 0, remainingData.Length);
                dataBuffer.Position = 0;
            }
        }

        // 然后，从网络流中读取剩余数据
        while (totalBytesRead < bytesToRead)
        {
            int currentReadSize = (int)Math.Min(readBuffer.Length, bytesToRead - totalBytesRead);
            int bytesJustRead = await networkStream.ReadAsync(readBuffer, 0, currentReadSize);
            if (bytesJustRead == 0)
            {
                throw new EndOfStreamException($"Server: Network stream ended prematurely while reading {bytesToRead} bytes. Read {totalBytesRead}.");
            }
            await resultBuffer.WriteAsync(readBuffer, 0, bytesJustRead);
            totalBytesRead += bytesJustRead;
        }

        return resultBuffer.ToArray();
    }



